---
/**
 * contact.astro — Página de Contacto
 * Basado en mockup: contact_desktop
 * Layout: 2 columnas — izquierda info | derecha formulario
 */
import PageLayout from "@layouts/PageLayout.astro";
import ContactForm from "@components/contact/ContactForm.astro";
import ContactMethods from "@components/contact/ContactMethods.astro";
import LocationCard from "@components/contact/LocationCard.astro";
import { SITE } from "@utils/constants";
---

<PageLayout
  title="Contact"
  description="Hire Carlos Posada — Cloud & DevOps Engineer. Available for full-time roles, freelance infrastructure projects, and consulting. Based in Medellín, Colombia."
  schemaType="contact"
>
  <div class="relative pt-32 pb-20 px-6 md:px-8 max-w-screen-2xl mx-auto min-h-screen">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- ── Panel izquierdo: identidad + canales ───── -->
      <div class="flex flex-col space-y-10">

        <!-- Header -->
        <div class="space-y-5">
          <!-- Badge disponibilidad -->
          <span
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full
                   bg-secondary/10 border border-secondary/30
                   text-secondary font-label text-xs tracking-widest uppercase"
          >
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse" aria-hidden="true"></span>
            Available for new projects
          </span>

          <!-- Headline -->
          <h1
            class="font-headline font-bold text-on-surface leading-tight tracking-tighter"
            style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
          >
            Let&apos;s{" "}
            <span class="text-primary italic">Connect</span>
          </h1>

          <p class="text-lg text-on-surface-variant max-w-md font-body leading-relaxed">
            Ready to architect your next high-velocity cloud solution or automate
            your QA pipelines? Drop a message and let&apos;s start building.
          </p>
        </div>

        <!-- Ubicación + timezone -->
        <LocationCard />

        <!-- Canales de contacto -->
        <div class="space-y-4">
          <h2 class="text-xs font-label uppercase tracking-widest text-on-surface-variant">
            Preferred Channels
          </h2>
          <ContactMethods />
        </div>
      </div>

      <!-- ── Panel derecho: formulario ─────────────── -->
      <div class="lg:sticky lg:top-28">
        <ContactForm />
      </div>

    </div>
  </div>
</PageLayout>
