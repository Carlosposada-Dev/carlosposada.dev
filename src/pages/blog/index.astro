---
/**
 * blog/index.astro — Blog Listing Page
 * Shows featured post (wide) + remaining posts in a grid.
 * Filters are planned for Phase 4 polish.
 */
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import PostCard from "@components/blog/PostCard.astro";

// Get all non-draft posts, sorted newest first
const allPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

const featuredPost = allPosts.find((p) => p.data.featured);
const regularPosts = allPosts.filter((p) => !p.data.featured);
---

<PageLayout
  title="Blog"
  description="Technical articles on Cloud, DevOps, QA Automation, and AI by Carlos Posada — deep dives into Terraform, Kubernetes, CI/CD pipelines, LLMs, and more."
  schemaType="blog"
>
  <div class="pt-32 pb-20 px-6 md:px-8 max-w-screen-2xl mx-auto">

    <!-- Page header -->
    <header class="mb-16 scroll-reveal fade-up">
      <p class="section-label text-secondary mb-3">Technical Writing</p>
      <h1
        class="font-headline font-bold tracking-tighter leading-none mb-6"
        style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
      >
        The <span class="text-gradient-animated">Infrastructure</span> Blog
      </h1>
      <p class="max-w-2xl text-on-surface-variant text-lg leading-relaxed">
        Deep dives into cloud architecture, DevOps practices, QA automation, and AI integrations.
        No paywalls. No fluff. Just working code.
      </p>

      <!-- Post count -->
      <div class="flex items-center gap-3 mt-6">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="font-mono text-sm text-on-surface-variant">
          {allPosts.length} article{allPosts.length !== 1 ? "s" : ""} published
        </span>
      </div>
    </header>

    {allPosts.length === 0 ? (
      <!-- Empty state -->
      <div class="text-center py-20 space-y-4">
        <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">article</span>
        <p class="font-headline text-xl font-bold text-on-surface/60">Articles coming soon</p>
        <p class="text-on-surface-variant text-sm">First post is almost ready. Stay tuned.</p>
      </div>
    ) : (
      <div class="space-y-8">
        <!-- Featured post (full-width card) -->
        {featuredPost && (
          <div class="scroll-reveal fade-up" style="--reveal-delay: 100ms;">
            <p class="section-label text-primary mb-4">Featured Article</p>
            <div class="grid grid-cols-1 md:grid-cols-2">
              <PostCard
                title={featuredPost.data.title}
                description={featuredPost.data.description}
                slug={featuredPost.slug}
                publishedDate={featuredPost.data.publishedDate}
                category={featuredPost.data.category}
                tags={featuredPost.data.tags}
                readingTime={featuredPost.data.readingTime}
                featured={true}
                coverImage={featuredPost.data.coverImage}
                coverImageAlt={featuredPost.data.coverImageAlt}
              />
            </div>
          </div>
        )}

        <!-- Regular posts grid -->
        {regularPosts.length > 0 && (
          <div>
            <p class="section-label text-on-surface-variant mb-4">All Articles</p>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {regularPosts.map((post, i) => (
                <div class="scroll-reveal fade-up" style={`--reveal-delay: ${(i + 1) * 100}ms;`}>
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    slug={post.slug}
                    publishedDate={post.data.publishedDate}
                    category={post.data.category}
                    tags={post.data.tags}
                    readingTime={post.data.readingTime}
                    coverImage={post.data.coverImage}
                    coverImageAlt={post.data.coverImageAlt}
                  />
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</PageLayout>
