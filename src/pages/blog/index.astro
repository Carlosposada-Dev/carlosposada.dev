---
/**
 * blog/index.astro — Blog Listing
 * Placeholder para Fase 4.
 * Basado en mockups: tech_blog_desktop / tech_blog_mobile
 */
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="Blog" description="Technical articles on Cloud, DevOps, QA Automation, and AI by Carlos Posada.">
  <div class="min-h-screen pt-32 pb-20 px-6 md:px-8 max-w-screen-2xl mx-auto flex items-center justify-center">
    <div class="text-center space-y-4">
      <p class="section-label text-secondary">Coming Soon</p>
      <h1 class="font-headline text-4xl font-bold text-white">Tech Blog</h1>
      <p class="text-on-surface-variant">Articles are being written for Phase 4.</p>
      <a href="/" class="btn-primary inline-flex mt-4">Back to Home</a>
    </div>
  </div>
</PageLayout>
