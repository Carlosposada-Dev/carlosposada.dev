---
/**
 * about.astro — About Me Page
 * Layout:
 *   Top: 5/12 photo+social (sticky) | 7/12 bio+timeline
 *   Bottom: full-width certifications badge wall
 */
import PageLayout from "@layouts/PageLayout.astro";
import ProfileCard from "@components/about/ProfileCard.astro";
import BioSection from "@components/about/BioSection.astro";
import Certifications from "@components/about/Certifications.astro";
import CareerTimeline from "@components/about/CareerTimeline.astro";
import CTABanner from "@components/home/CTABanner.astro";
---

<PageLayout
  title="About Me"
  description="Carlos Posada — Cloud & DevOps Engineer and AI Solutions Lead with 10+ years of experience in AWS, Kubernetes, Terraform, and QA Automation. Based in Medellín, Colombia."
  schemaType="about"
>
  <main class="pt-32 pb-20 px-6 md:px-8 max-w-screen-2xl mx-auto space-y-20">

    <!-- ── Two-column hero: photo + bio/timeline ─────────── -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Left column: photo + social links (sticky on desktop) -->
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-28">
          <ProfileCard />
        </div>
      </div>

      <!-- Right column: bio + career timeline -->
      <div class="lg:col-span-7 space-y-16">
        <BioSection />
        <CareerTimeline />
      </div>

    </div>

    <!-- ── Full-width certifications badge wall ───────────── -->
    <Certifications />

  </main>

  <CTABanner />
</PageLayout>
