---
/**
 * FeaturedProjects.astro
 * Sección "Portfolio" con 3 proyectos destacados en Home.
 * Cards con imagen, badge de categoría, descripción y tags de tecnología.
 */
import { FEATURED_PROJECTS } from "@utils/constants";

// Colores para badges y tags según categoría
const badgeStyles = {
  primary: "bg-primary-container text-on-primary-container",
  secondary: "bg-secondary-container text-on-secondary-container",
  tertiary: "bg-tertiary-container text-on-tertiary-container",
};

// Imágenes placeholder por proyecto (serán reemplazadas con imágenes reales)
const projectImages: Record<string, { src: string; alt: string }> = {
  "multi-cloud-drifting": {
    src: "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&q=80",
    alt: "Abstract server network visualization with glowing nodes on dark background",
  },
  "self-healing-framework": {
    src: "https://images.unsplash.com/photo-1504639725590-34d0984388bd?w=600&q=80",
    alt: "Digital dashboard showing analytics and code patterns",
  },
  "infra-intelligence-bot": {
    src: "https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=600&q=80",
    alt: "AI neural network visualization with glowing connections",
  },
};
---

<section
  class="py-section md:py-section-lg bg-surface-container-low"
  aria-labelledby="portfolio-heading"
>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-8">

    <!-- Header -->
    <div class="mb-14">
      <p class="section-label text-primary mb-3">Portfolio</p>
      <h2
        id="portfolio-heading"
        class="font-headline text-3xl md:text-4xl font-bold text-white"
      >
        Engineered for Impact
      </h2>
    </div>

    <!-- Grid de proyectos -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {FEATURED_PROJECTS.map((project) => {
        const img = projectImages[project.id];
        const badge = badgeStyles[project.badgeColor];
        return (
          <article class="card-hover flex flex-col overflow-hidden">

            <!-- Imagen del proyecto -->
            <div class="h-48 relative overflow-hidden bg-surface-container-high">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover transition-transform duration-700
                       group-hover:scale-105 opacity-70"
                loading="lazy"
                decoding="async"
                width="600"
                height="192"
              />
              <!-- Overlay gradiente para legibilidad -->
              <div
                class="absolute inset-0 bg-gradient-to-t from-surface-container via-transparent to-transparent"
                aria-hidden="true"
              ></div>
              <!-- Badge de categoría -->
              <span
                class:list={["absolute top-4 right-4 badge text-[10px]", badge]}
              >
                {project.badge}
              </span>
            </div>

            <!-- Contenido -->
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-headline text-xl font-bold text-white mb-2 leading-snug">
                {project.title}
              </h3>
              <p class="text-on-surface-variant text-sm leading-relaxed mb-6 flex-1">
                {project.description}
              </p>

              <!-- Tags de tecnología -->
              <div class="flex flex-wrap gap-2 mb-6">
                {project.tags.map((tag) => (
                  <span class:list={[`tech-tag-${tag.color}`]}>{tag.label}</span>
                ))}
              </div>

              <!-- CTA -->
              <a
                href={project.href}
                class="flex items-center justify-center gap-2 w-full py-3 rounded-lg
                       border border-outline text-on-surface font-headline font-bold text-sm
                       hover:bg-primary hover:text-on-primary hover:border-primary
                       transition-all duration-200"
              >
                View Project
                <span class="material-symbols-outlined text-sm" aria-hidden="true">
                  open_in_new
                </span>
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Ver todos los proyectos -->
    <div class="mt-12 flex justify-center">
      <a
        href="/projects"
        class="btn-ghost inline-flex"
      >
        View All Projects
        <span class="material-symbols-outlined text-lg" aria-hidden="true">
          arrow_forward
        </span>
      </a>
    </div>
  </div>
</section>
