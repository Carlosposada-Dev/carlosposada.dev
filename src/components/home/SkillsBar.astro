---
/**
 * SkillsBar.astro
 * Banda horizontal con el stack tecnológico.
 * Efecto: grayscale por defecto, color al hover de la sección completa.
 * En mobile: scroll horizontal sin scrollbar.
 */
import { SKILLS } from "@utils/constants";
---

<section
  class="py-12 border-y border-outline-variant/20 bg-surface-container-low overflow-hidden"
  aria-label="Tech stack"
>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
    <!-- Scrollable en mobile, distribuido en desktop -->
    <div
      class="flex gap-8 md:gap-6
             overflow-x-auto no-scrollbar
             md:overflow-visible md:flex-wrap
             md:justify-center lg:justify-between
             items-center
             opacity-60 grayscale
             hover:grayscale-0 hover:opacity-100
             transition-all duration-700"
      role="list"
      aria-label="Technologies I work with"
    >
      {SKILLS.map((skill) => (
        <div
          class="flex items-center gap-2 text-on-surface
                 font-headline font-bold text-sm
                 flex-shrink-0 whitespace-nowrap"
          role="listitem"
        >
          <span
            class="material-symbols-outlined text-primary text-xl"
            aria-hidden="true"
          >
            {skill.icon}
          </span>
          {skill.label}
        </div>
      ))}
    </div>
  </div>
</section>
