---
/**
 * ServicesPreview.astro
 * Sección "Core Expertise" en Home.
 * Muestra 3 cards de servicios (preview).
 * Cada card tiene acento de color según el tipo de servicio.
 */
import { SERVICES } from "@utils/constants";

// Mapa de colores por tipo de servicio según design system
const colorMap = {
  primary: {
    icon: "bg-primary/10 text-primary border-primary/20",
    bullet: "bg-primary",
    cardHover: "hover:border-primary/50",
    cardBorder: "border-outline-variant/20",
  },
  secondary: {
    icon: "bg-secondary/10 text-secondary border-secondary/20",
    bullet: "bg-secondary",
    cardHover: "hover:border-secondary/50",
    cardBorder: "border-secondary/10",
  },
  tertiary: {
    icon: "bg-tertiary/10 text-tertiary border-tertiary/20",
    bullet: "bg-tertiary",
    cardHover: "hover:border-tertiary/50",
    cardBorder: "border-outline-variant/20",
  },
};
---

<section class="py-section md:py-section-lg bg-surface" aria-labelledby="services-heading">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-8">

    <!-- Header de sección -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-6 scroll-reveal fade-up">
      <div class="max-w-2xl">
        <p class="section-label text-primary mb-3" id="services-heading">Core Expertise</p>
        <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
          Solving Complexity<br class="hidden sm:block" /> Through Automation.
        </h2>
      </div>
      <p class="text-on-surface-variant max-w-sm text-sm leading-relaxed">
        Specialized services designed to accelerate development cycles and ensure
        infrastructure stability.
      </p>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {SERVICES.map((service, index) => {
        const colors = colorMap[service.accentColor];
        return (
          <article
            class:list={[
              "glass-card p-8 rounded-xl group scroll-reveal fade-up",
              "border transition-all duration-300",
              colors.cardBorder,
              colors.cardHover,
            ]}
            style={`--reveal-delay: ${index * 100}ms;`}
          >
            <!-- Ícono -->
            <div
              class:list={[
                "w-12 h-12 rounded-lg flex items-center justify-center mb-6",
                "border group-hover:scale-110 transition-transform duration-300",
                colors.icon,
              ]}
              aria-hidden="true"
            >
              <span class="material-symbols-outlined">{service.icon}</span>
            </div>

            <!-- Título -->
            <h3 class="font-headline text-xl font-bold text-white mb-4">
              {service.title}
            </h3>

            <!-- Descripción -->
            <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
              {service.shortDescription}
            </p>

            <!-- Bullets -->
            <ul class="space-y-2 mb-8" role="list">
              {service.bullets.map((bullet) => (
                <li class="flex items-center gap-2 text-xs text-on-surface/70 font-mono">
                  <span
                    class:list={["w-1.5 h-1.5 rounded-full flex-shrink-0", colors.bullet]}
                    aria-hidden="true"
                  ></span>
                  {bullet}
                </li>
              ))}
            </ul>

            <!-- Link a página de servicios -->
            <a
              href={`/services#${service.id}`}
              class="inline-flex items-center gap-1 text-xs font-headline font-bold
                     text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest"
            >
              Learn more
              <span class="material-symbols-outlined text-sm" aria-hidden="true">
                arrow_forward
              </span>
            </a>
          </article>
        );
      })}
    </div>
  </div>
</section>
