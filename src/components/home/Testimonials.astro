---
/**
 * Testimonials.astro
 * Sección "Verified Professional Impact".
 * Estadísticas de impacto + testimonial destacado.
 */
---

<section
  class="py-section md:py-section-lg border-y border-outline-variant/10"
  aria-labelledby="testimonials-heading"
>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- ── Columna izquierda: stats e impacto ──────── -->
      <div class="space-y-8">
        <div>
          <h2
            id="testimonials-heading"
            class="font-headline text-2xl md:text-3xl font-bold text-white mb-4"
          >
            Verified Professional Impact
          </h2>
          <p class="text-on-surface-variant leading-relaxed">
            Collaborating with cross-functional teams to deliver stable, scalable
            infrastructure that powers modern software.
          </p>
        </div>

        <!-- Métricas -->
        <div class="grid grid-cols-2 gap-6">
          <div class="terminal-block rounded-xl">
            <p class="font-headline text-3xl font-bold text-primary mb-1">50+</p>
            <p class="text-on-surface-variant text-sm">Projects Delivered</p>
          </div>
          <div class="terminal-block rounded-xl">
            <p class="font-headline text-3xl font-bold text-secondary mb-1">99.9%</p>
            <p class="text-on-surface-variant text-sm">Uptime SLA Met</p>
          </div>
          <div class="terminal-block rounded-xl">
            <p class="font-headline text-3xl font-bold text-tertiary mb-1">70%</p>
            <p class="text-on-surface-variant text-sm">QA Cycle Reduction</p>
          </div>
          <div class="terminal-block rounded-xl">
            <p class="font-headline text-3xl font-bold text-primary mb-1">10+</p>
            <p class="text-on-surface-variant text-sm">Years of Experience</p>
          </div>
        </div>

        <!-- Avatares + social proof -->
        <div class="flex items-center gap-4">
          <div class="flex -space-x-3" aria-hidden="true">
            <div class="w-10 h-10 rounded-full border-2 border-surface bg-primary/20
                        flex items-center justify-center font-headline font-bold text-xs text-primary">
              JD
            </div>
            <div class="w-10 h-10 rounded-full border-2 border-surface bg-secondary/20
                        flex items-center justify-center font-headline font-bold text-xs text-secondary">
              MS
            </div>
            <div class="w-10 h-10 rounded-full border-2 border-surface bg-tertiary/20
                        flex items-center justify-center font-headline font-bold text-xs text-tertiary">
              RK
            </div>
          </div>
          <div>
            <p class="font-headline font-bold text-white text-sm">Trusted by Global Teams</p>
            <p class="text-primary text-xs font-mono">From startups to Fortune 500</p>
          </div>
        </div>
      </div>

      <!-- ── Columna derecha: testimonial card ─────── -->
      <div>
        <blockquote
          class="glass-card p-6 md:p-8 rounded-xl relative overflow-hidden group"
        >
          <!-- Ícono decorativo de comillas -->
          <span
            class="absolute top-0 right-0 p-4 font-headline text-7xl leading-none
                   text-primary/10 group-hover:text-primary/25 transition-colors
                   select-none pointer-events-none"
            aria-hidden="true"
          >
            &ldquo;
          </span>

          <p class="italic text-on-surface/90 leading-relaxed relative z-10 text-sm md:text-base">
            &ldquo;Carlos transformed our deployment process. We went from weekly manual
            releases to daily automated deploys with zero downtime. A truly exceptional
            DevOps engineer who understands both the technical depth and business impact.&rdquo;
          </p>

          <!-- Autor -->
          <footer class="mt-6 flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-full bg-surface-variant border border-primary/20
                     flex items-center justify-center font-headline font-bold text-primary text-xs"
              aria-hidden="true"
            >
              SE
            </div>
            <div>
              <cite class="not-italic font-headline font-bold text-white text-sm not-italic">
                Senior Engineering Manager
              </cite>
              <p class="text-primary text-xs font-mono">Leading Tech Startup</p>
            </div>
          </footer>
        </blockquote>
      </div>

    </div>
  </div>
</section>
