---
/**
 * ServiceTile.astro
 * Tile de servicio para la página /services.
 * Diseño horizontal (normal o invertido) con:
 *  - borde izquierdo de color de acento
 *  - ícono grande, título y descripción
 *  - lista de deliverables con íconos
 *  - imagen que pasa de grayscale a color al hover
 *  - CTA a /contact con estilo según el servicio
 */
import type { ServiceDetail } from "@utils/constants";

export interface Props {
  service: ServiceDetail;
}

const { service } = Astro.props;

// Mapa de estilos según accentColor
const styles = {
  primary: {
    icon: "bg-primary/10 text-primary border-primary/20",
    deliverableIcon: "text-primary",
    subLabel: "text-secondary",
    cta: "bg-primary text-on-primary-container hover:shadow-glow-primary-md",
    hover: "hover:bg-surface-container-high",
    glow: "shadow-glow-primary",
  },
  secondary: {
    icon: "bg-secondary/10 text-secondary border-secondary/20",
    deliverableIcon: "text-secondary",
    subLabel: "text-primary",
    cta: "border border-secondary text-secondary hover:bg-secondary/10 hover:shadow-glow-secondary",
    hover: "hover:bg-surface-container-high",
    glow: "shadow-glow-secondary",
  },
  tertiary: {
    icon: "bg-tertiary/10 text-tertiary border-tertiary/20",
    deliverableIcon: "text-tertiary",
    subLabel: "text-secondary",
    cta: "bg-tertiary-container text-on-tertiary-container hover:shadow-[0_0_25px_rgba(111,148,250,0.4)]",
    hover: "hover:bg-surface-container-high",
    glow: "shadow-[0_0_20px_rgba(130,163,255,0.1)]",
  },
};

const s = styles[service.accentColor];
const isReverse = service.layout === "reverse";
---

<article
  id={service.id}
  class:list={[
    "group relative bg-surface-container",
    "border-l-4", service.accentBorder,
    "p-8 md:p-12",
    "transition-all duration-500",
    s.hover, s.glow,
    "flex gap-10 items-start",
    isReverse ? "flex-col md:flex-row-reverse" : "flex-col md:flex-row",
  ]}
>
  <!-- ── Columna info (1/3) ──────────────────────────── -->
  <div class="w-full md:w-1/3 flex flex-col gap-5 flex-shrink-0">

    <!-- Ícono del servicio -->
    <div
      class:list={[
        "w-20 h-20 rounded-lg flex items-center justify-center border",
        "group-hover:scale-105 transition-transform duration-300",
        s.icon,
      ]}
      aria-hidden="true"
    >
      <span class="material-symbols-outlined text-4xl">{service.icon}</span>
    </div>

    <!-- Título -->
    <h2 class="font-headline text-2xl md:text-3xl font-bold text-on-surface leading-tight">
      {service.title}
    </h2>

    <!-- Descripción larga -->
    <p class="text-on-surface-variant text-sm leading-relaxed">
      {service.longDescription}
    </p>
  </div>

  <!-- ── Columna deliverables + imagen + CTA (flex-1) ── -->
  <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- Lista de deliverables -->
    <div class="space-y-4">
      <h3 class:list={["text-xs font-headline font-bold uppercase tracking-widest", s.subLabel]}>
        Deliverables
      </h3>
      <ul class="space-y-3" role="list">
        {service.deliverables.map((d) => (
          <li class="flex items-start gap-3 text-on-surface/80 text-sm">
            <span
              class:list={["material-symbols-outlined text-base flex-shrink-0 mt-0.5", s.deliverableIcon]}
              aria-hidden="true"
            >
              {d.icon}
            </span>
            {d.label}
          </li>
        ))}
      </ul>
    </div>

    <!-- Imagen + CTA -->
    <div class:list={[
      "flex flex-col gap-6 justify-end",
      isReverse ? "items-start" : "items-end",
    ]}>
      <!-- Imagen (grayscale → color al hover del article) -->
      <div class="w-full h-40 overflow-hidden rounded-lg">
        <img
          src={service.image}
          alt={service.imageAlt}
          class="w-full h-full object-cover
                 opacity-40 grayscale
                 group-hover:opacity-60 group-hover:grayscale-0
                 transition-all duration-700"
          loading="lazy"
          decoding="async"
          width="400"
          height="160"
        />
      </div>

      <!-- CTA -->
      <a
        href="/contact"
        class:list={[
          "w-full md:w-auto text-center",
          "px-8 py-4 rounded-lg font-headline font-bold text-sm",
          "active:scale-95 transition-all duration-200",
          s.cta,
        ]}
      >
        Contact for this Service
      </a>
    </div>
  </div>
</article>
