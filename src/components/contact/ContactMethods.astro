---
/**
 * ContactMethods.astro
 * Lista de canales de contacto preferidos:
 * Email, LinkedIn, GitHub, WhatsApp.
 * Cada item tiene ícono SVG de marca, label y flecha animada al hover.
 */
import { SITE, SOCIAL_LINKS } from "@utils/constants";

// Ícono de email como SVG (Material Symbols no tiene iconos de marca)
const EMAIL_SVG =
  "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z";

const getSocial = (label: string) => SOCIAL_LINKS.find((s) => s.label === label);

const methods = [
  {
    label: "Email",
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    svgPath: EMAIL_SVG,
    external: false,
  },
  {
    label: "LinkedIn",
    value: "carlos-andres-posada-chica",
    href: getSocial("LinkedIn")?.href ?? "#",
    svgPath: getSocial("LinkedIn")?.svgPath ?? "",
    external: true,
  },
  {
    label: "GitHub",
    value: "Carlosposada-Dev",
    href: getSocial("GitHub")?.href ?? "#",
    svgPath: getSocial("GitHub")?.svgPath ?? "",
    external: true,
  },
  {
    label: "WhatsApp",
    value: "+57 · WhatsApp",
    href: getSocial("WhatsApp")?.href ?? "#",
    svgPath: getSocial("WhatsApp")?.svgPath ?? "",
    external: true,
  },
];
---

<div class="space-y-4" role="list" aria-label="Contact channels">
  {methods.map((method) => (
    <a
      href={method.href}
      role="listitem"
      target={method.external ? "_blank" : undefined}
      rel={method.external ? "noopener noreferrer" : undefined}
      class="group flex items-center gap-4 p-4 rounded-xl
             bg-surface-container-low hover:bg-surface-container
             border border-transparent hover:border-primary/30
             transition-all duration-300"
      aria-label={`${method.label}: ${method.value}`}
    >
      <!-- Ícono SVG de marca -->
      <div
        class="w-12 h-12 flex-shrink-0 flex items-center justify-center rounded-lg
               bg-primary/10 text-primary
               group-hover:bg-primary group-hover:text-on-primary
               transition-all duration-200"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 24 24"
          class="w-5 h-5 fill-current"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d={method.svgPath} />
        </svg>
      </div>

      <!-- Texto -->
      <div class="min-w-0">
        <p class="text-xs text-on-surface-variant font-body mb-0.5">{method.label}</p>
        <p class="font-headline font-bold text-on-surface truncate">{method.value}</p>
      </div>

      <!-- Flecha animada -->
      <span
        class="material-symbols-outlined ml-auto text-on-surface-variant
               opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5
               transition-all duration-200 flex-shrink-0"
        aria-hidden="true"
      >
        arrow_outward
      </span>
    </a>
  ))}
</div>
