---
/**
 * SchemaOrg.astro
 * Genera JSON-LD structured data para Google Rich Results y LLMs.
 * Se incluye en BaseLayout.astro via <slot name="head">.
 *
 * Schemas implementados:
 * - Person (identidad profesional)
 * - WebSite (bГєsqueda de sitio)
 * - WebPage (cada pГЎgina individual)
 * - ProfessionalService (servicios ofrecidos)
 *
 * Referencia: https://schema.org / https://developers.google.com/search/docs/appearance/structured-data
 */
import { SITE, SOCIAL_LINKS, SKILLS, SERVICES } from "@utils/constants";

export interface Props {
  /** Tipo de pГЎgina para schema contextual */
  type?: "home" | "about" | "services" | "projects" | "contact" | "blog" | "article";
  /** TГ­tulo de la pГЎgina */
  title?: string;
  /** DescripciГіn de la pГЎgina */
  description?: string;
  /** URL canГіnica */
  url?: string;
  /** Datos del artГ­culo (solo para type="article") */
  article?: {
    title: string;
    description: string;
    datePublished: string;
    dateModified?: string;
    tags?: string[];
    image?: string;
  };
}

const {
  type = "home",
  title = SITE.title,
  description = SITE.description,
  url = SITE.url,
  article,
} = Astro.props;

// в”Ђв”Ђ Person Schema вЂ” identidad profesional в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const personSchema = {
  "@type": "Person",
  "@id": `${SITE.url}/#person`,
  name: SITE.author,
  url: SITE.url,
  email: SITE.email,
  jobTitle: "Cloud & DevOps Engineer",
  description:
    "Cloud & DevOps Engineer specializing in AWS, Terraform, Kubernetes, CI/CD pipelines, QA Automation, and AI-powered infrastructure solutions.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "MedellГ­n",
    addressCountry: "CO",
  },
  sameAs: SOCIAL_LINKS.map((s) => s.href),
  knowsAbout: [
    ...SKILLS.map((s) => s.label),
    "CI/CD Pipelines",
    "Infrastructure as Code",
    "Cloud Architecture",
    "Site Reliability Engineering",
    "Test Automation",
    "DevSecOps",
    "LLM Integration",
    "MLOps",
  ],
};

// в”Ђв”Ђ WebSite Schema вЂ” bГєsqueda del sitio в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const websiteSchema = {
  "@type": "WebSite",
  "@id": `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { "@id": `${SITE.url}/#person` },
  inLanguage: "en-US",
};

// в”Ђв”Ђ WebPage Schema вЂ” la pГЎgina actual в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const webPageSchema = {
  "@type": "WebPage",
  "@id": `${url}/#webpage`,
  url: url,
  name: title,
  description: description,
  isPartOf: { "@id": `${SITE.url}/#website` },
  about: { "@id": `${SITE.url}/#person` },
  inLanguage: "en-US",
};

// в”Ђв”Ђ ProfessionalService Schema вЂ” servicios ofrecidos в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const serviceSchema = {
  "@type": "ProfessionalService",
  "@id": `${SITE.url}/#services`,
  name: `${SITE.author} вЂ” Cloud & DevOps Services`,
  url: `${SITE.url}/services`,
  provider: { "@id": `${SITE.url}/#person` },
  areaServed: "Worldwide",
  serviceType: SERVICES.map((s) => s.title),
  description:
    "Professional DevOps consulting, cloud architecture, QA automation, and AI integration services for startups and enterprises.",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Engineering Services",
    itemListElement: SERVICES.map((s, i) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: s.title,
        description: s.shortDescription,
      },
      position: i + 1,
    })),
  },
};

// в”Ђв”Ђ Article Schema вЂ” para posts del blog в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const articleSchema = article
  ? {
      "@type": "Article",
      "@id": `${url}/#article`,
      headline: article.title,
      description: article.description,
      datePublished: article.datePublished,
      dateModified: article.dateModified ?? article.datePublished,
      author: { "@id": `${SITE.url}/#person` },
      publisher: { "@id": `${SITE.url}/#person` },
      mainEntityOfPage: { "@id": `${url}/#webpage` },
      inLanguage: "en-US",
      ...(article.image && { image: new URL(article.image, SITE.url).toString() }),
      ...(article.tags && { keywords: article.tags.join(", ") }),
    }
  : null;

// в”Ђв”Ђ Ensamblar el @graph segГєn el tipo de pГЎgina в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
const graphItems: Record<string, unknown>[] = [personSchema, websiteSchema, webPageSchema];

if (type === "services" || type === "home") {
  graphItems.push(serviceSchema);
}
if (type === "article" && articleSchema) {
  graphItems.push(articleSchema);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graphItems,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
