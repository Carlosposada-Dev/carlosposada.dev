---
/**
 * BottomNav.astro
 * Navegación inferior fija para dispositivos móviles.
 * Visible solo en pantallas < md (768px).
 * Muestra 4 items principales con íconos y labels.
 */
import { MOBILE_NAV_ITEMS } from "@utils/constants";

export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

/**
 * Determina si un link es el activo
 */
function isActive(href: string, current: string): boolean {
  if (href === "/") return current === "/";
  return current.startsWith(href);
}
---

<nav
  class="fixed bottom-0 left-0 w-full md:hidden z-50
         flex justify-around items-center
         px-4 pb-safe-bottom pt-2
         bg-surface/90 backdrop-blur-lg
         border-t border-surface-variant
         shadow-[0_-4px_12px_rgba(0,0,0,0.5)]
         rounded-t-xl"
  aria-label="Mobile bottom navigation"
  role="navigation"
>
  {MOBILE_NAV_ITEMS.map((item) => {
    const active = isActive(item.href, currentPath);
    return (
      <a
        href={item.href}
        class:list={[
          "flex flex-col items-center justify-center gap-0.5",
          "min-w-[48px] py-1 px-3 rounded-lg",
          "font-label text-[10px] uppercase tracking-widest font-medium",
          "transition-all duration-200",
          active
            ? "text-primary bg-surface-container"
            : "text-on-surface/60 hover:text-primary",
        ]}
        aria-current={active ? "page" : undefined}
        aria-label={item.label}
      >
        <span
          class:list={[
            "material-symbols-outlined text-[22px]",
            active ? "material-symbols-filled" : "material-symbols-outlined",
          ]}
          aria-hidden="true"
        >
          {item.mobileIcon}
        </span>
        {item.label}
      </a>
    );
  })}
</nav>

<!-- Espaciado inferior en mobile para no tapar contenido con el nav -->
<div class="h-20 md:hidden" aria-hidden="true"></div>
