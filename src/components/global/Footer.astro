---
/**
 * Footer.astro
 * Footer global del sitio.
 * Links de redes sociales, copyright y links legales.
 */
import { SITE, SERVICES, SOCIAL_LINKS, FOOTER_LINKS } from "@utils/constants";

const year = new Date().getFullYear();
---

<footer class="relative mt-20 overflow-hidden">
  <!-- Gradient divider en vez de border -->
  <div class="h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent" aria-hidden="true"></div>

  <!-- Background mesh -->
  <div class="absolute inset-0 grid-mesh-dots opacity-5" aria-hidden="true"></div>

  <div class="relative max-w-screen-2xl mx-auto px-6 md:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      
      <!-- Col 1: Brand + tagline -->
      <div class="space-y-4 col-span-2 md:col-span-1">
        <a
          href="/"
          class="font-mono font-bold text-xl text-primary hover:text-primary-dim transition-colors inline-block"
          aria-label={`${SITE.name} — Home`}
        >
          {SITE.name}
        </a>
        <p class="text-sm text-on-surface-variant leading-relaxed max-w-xs">
          Engineering reliable cloud infrastructure and automated quality gates for modern software.
        </p>
      </div>

      <!-- Col 2: Expertise / Topics -->
      <div>
        <h3 class="font-headline font-bold text-white mb-4 uppercase tracking-wider text-sm">Expertise</h3>
        <ul class="space-y-3">
          {SERVICES.map((service) => (
            <li>
              <a
                href={`/services#${service.id}`}
                class="text-sm text-on-surface/60 hover:text-primary transition-colors duration-300"
              >
                {service.title}
              </a>
            </li>
          ))}
          <li>
            <a href="/projects" class="text-sm text-on-surface/60 hover:text-primary transition-colors duration-300">
              View All Projects
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Social -->
      <div>
        <h3 class="font-headline font-bold text-white mb-4 uppercase tracking-wider text-sm">Social</h3>
        <ul class="space-y-3">
          {SOCIAL_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-on-surface/60 hover:text-secondary transition-colors duration-300 flex items-center gap-2"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="w-4 h-4 fill-current" viewBox={link.svgViewBox || "0 0 24 24"} aria-hidden="true">
                  <path d={link.svgPath} />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Legal & Status -->
      <div>
        <h3 class="font-headline font-bold text-white mb-4 uppercase tracking-wider text-sm">Legal & Status</h3>
        <ul class="space-y-3 mb-6">
          {FOOTER_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-on-surface/60 hover:text-tertiary transition-colors duration-300"
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Status indicator -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface-container-low border border-outline-variant/20">
          <span class="status-dot scale-75" aria-hidden="true"></span>
          <span class="font-mono text-xs text-on-surface-variant">System Status: Online</span>
        </div>
      </div>

    </div>

    <!-- Copyright bar -->
    <div class="mt-16 pt-8 border-t border-outline-variant/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-body text-sm text-on-surface/40">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
      <p class="font-body text-sm text-on-surface/40 flex items-center gap-1">
        Built with <span class="text-secondary">&#9729;&#65039;</span> &amp; <span class="text-tertiary">&#9881;&#65039;</span>
      </p>
    </div>
  </div>
</footer>
