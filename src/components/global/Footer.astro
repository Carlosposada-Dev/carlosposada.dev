---
/**
 * Footer.astro
 * Footer global del sitio.
 * Links de redes sociales, copyright y links legales.
 */
import { SITE, FOOTER_LINKS } from "@utils/constants";

const year = new Date().getFullYear();
---

<footer class="w-full border-t border-surface-variant/50 bg-surface mt-20">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-8 py-10">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">

      <!-- Brand -->
      <a
        href="/"
        class="font-mono font-bold text-lg text-primary hover:text-primary-dim transition-colors"
        aria-label="carlosposada.dev — Home"
      >
        {SITE.name}
      </a>

      <!-- Links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-6 md:gap-8">
          {FOOTER_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-on-surface/40 hover:text-secondary transition-colors duration-300"
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Copyright -->
      <p class="font-body text-sm text-on-surface/60 text-center">
        &copy; {year} {SITE.name} | Built with &#9729;&#65039; &amp; &#9881;&#65039;
      </p>
    </div>
  </div>
</footer>
