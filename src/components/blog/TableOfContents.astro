---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  /** "sidebar" = sticky desktop nav | "mobile" = collapsible accordion */
  variant?: "sidebar" | "mobile";
}

const { headings, variant = "sidebar" } = Astro.props;
---

{variant === "sidebar" && (
  <nav
    aria-label="Table of contents"
    class="sticky top-28 max-h-[calc(100vh-8rem)] overflow-y-auto
           glass-card rounded-xl border border-outline-variant/20 p-5"
  >
    <p class="text-xs font-headline font-bold uppercase tracking-widest
              text-on-surface-variant/60 mb-4">
      On this page
    </p>
    <ol class="space-y-0.5" role="list">
      {headings.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            data-toc-link={h.slug}
            class:list={[
              "toc-link block py-1.5 text-sm leading-snug transition-colors duration-150",
              "text-on-surface-variant/60 hover:text-primary",
              h.depth === 3 ? "pl-4 text-xs" : "font-medium",
            ]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

{variant === "mobile" && (
  <details class="mb-8 glass-card rounded-xl border border-outline-variant/20 group">
    <summary
      class="flex items-center justify-between px-5 py-3.5 cursor-pointer
             text-sm font-headline font-bold text-on-surface-variant
             hover:text-primary transition-colors list-none"
    >
      <span class="flex items-center gap-2">
        <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">
          menu_book
        </span>
        Table of contents
      </span>
      <span
        class="material-symbols-outlined text-base transition-transform duration-200
               group-open:rotate-180"
        aria-hidden="true"
      >
        expand_more
      </span>
    </summary>
    <nav aria-label="Table of contents" class="px-5 pb-4 pt-1 border-t border-outline-variant/20">
      <ol class="space-y-0.5" role="list">
        {headings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                "block py-1.5 text-sm leading-snug transition-colors",
                "text-on-surface-variant hover:text-primary",
                h.depth === 3 ? "pl-4 text-xs" : "",
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
)}

<script>
  // Scroll-spy: highlights the active heading in the desktop sidebar
  document.addEventListener("astro:page-load", () => {
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (!links.length) return;

    let activeSlug = "";

    const setActive = (slug: string) => {
      if (slug === activeSlug) return;
      activeSlug = slug;
      links.forEach((link) => {
        const isActive = link.dataset.tocLink === slug;
        link.classList.toggle("!text-primary", isActive);
        link.classList.toggle("text-on-surface-variant/60", !isActive);
      });
    };

    const headingEls = Array.from(
      document.querySelectorAll<HTMLElement>("#post-body h2[id], #post-body h3[id]")
    );
    if (!headingEls.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));

    // Close mobile accordion on link click
    document.querySelectorAll(".toc-mobile-link").forEach((a) => {
      a.addEventListener("click", () => {
        (a.closest("details") as HTMLDetailsElement | null)?.removeAttribute("open");
      });
    });
  });
</script>
