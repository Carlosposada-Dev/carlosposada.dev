---
/**
 * PageLayout.astro
 * Layout para páginas estáticas (About, Projects, Services, Contact).
 * Incluye Navbar, BottomNav mobile y Footer.
 * Extiende BaseLayout con el shell de navegación completo.
 */
import BaseLayout from "./BaseLayout.astro";
import Navbar from "@components/global/Navbar.astro";
import Footer from "@components/global/Footer.astro";
import BottomNav from "@components/global/BottomNav.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import { SITE } from "@utils/constants";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  /** Tipo de página para Schema.org structured data */
  schemaType?: "home" | "about" | "services" | "projects" | "contact" | "blog" | "article";
}

const { title, description, canonical, ogImage, ogType, schemaType = "home" } = Astro.props;

// URL canónica de esta página
const pageUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();

// Ruta activa para highlight en nav
const currentPath = Astro.url.pathname;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType={ogType}
>
  <!-- Schema.org JSON-LD structured data -->
  <SchemaOrg
    slot="head"
    type={schemaType}
    title={title ? `${title} | ${SITE.name}` : SITE.title}
    description={description ?? SITE.description}
    url={pageUrl}
  />
  <!-- Textura de fondo global — blueprint dots -->
  <div class="fixed inset-0 grid-mesh-dots pointer-events-none -z-10" aria-hidden="true"></div>

  <!-- Navegación principal (desktop) -->
  <Navbar currentPath={currentPath} />

  <!-- Contenido de la página -->
  <main id="main-content" class="relative z-0">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- Bottom nav (solo mobile) -->
  <BottomNav currentPath={currentPath} />
</BaseLayout>
